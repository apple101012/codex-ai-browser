HOST=127.0.0.1
PORT=4321
DATA_DIR=./data
# Optional: set to a VPS-mounted folder or network share for profile backup snapshots.
BACKUP_DIR=./data/backups
DEFAULT_HEADLESS=true
ALLOW_EVALUATE=false
# Optional acceleration extension (Chromium-family). Core snapshot acceleration still works without it.
ENABLE_ACCELERATOR_EXTENSION=false
ACCELERATOR_EXTENSION_DIR=./extension/ai-browser-accelerator
ENABLE_SNAPSHOT_CACHE=false
# Set API_TOKEN in production or if exposing outside localhost.
API_TOKEN=change-me
