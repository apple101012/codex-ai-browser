{
  "name": "codex-ai-browser",
  "version": "0.1.0",
  "description": "AI-focused multi-profile browser runtime with API + MCP control",
  "main": "electron/main.cjs",
  "scripts": {
    "test": "vitest run --coverage",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "start:api": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "mcp": "tsx src/mcp.ts",
    "profile:gemini": "tsx src/scripts/ensureGeminiProfile.ts",
    "desktop:dev": "npm run build && electron .",
    "desktop:build": "npm run build && electron-builder --win portable",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "fastify": "^5.8.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.58.2",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.2.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  },
  "type": "module",
  "build": {
    "appId": "com.apple101012.codexaibrowser",
    "productName": "Codex AI Browser",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "electron/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "dist/**"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
